# API Configuration
API_V1_STR=/api/v1
DEBUG=false
ENVIRONMENT=production

# Server Configuration
SERVER_NAME=PageIQ
SERVER_HOST=https://pageiq.pompora.dev
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DATABASE_URL=sqlite+pysqlite:///./pageiq.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# RapidAPI Configuration
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret-here

# Security
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
BACKEND_CORS_ORIGINS=https://pageiq.pompora.dev,https://www.pageiq.com,http://localhost:3000,http://localhost:8080

# Stripe Integration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_IDS={"free":null,"basic":"price_basic","pro":"price_pro","business":"price_business","enterprise":"price_enterprise"}

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=pageiq-screenshots

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=info

# Monitoring
SENTRY_DSN=
JAEGER_TRACE_ENDPOINT=

# Free Tier Settings
FREE_TIER_REQUESTS_PER_MONTH=100
FREE_TIER_SLOW_QUEUE=true

# Cache
CACHE_TTL_SECONDS=86400

# Screenshots
SCREENSHOTS_DIR=data/screenshots
SCREENSHOTS_URL_PREFIX=/screenshots

# Batch Processing
BATCH_STATUS_TTL_SECONDS=86400